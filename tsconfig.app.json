{
    "extends": "./../../../../tsconfig.base.json",
    "compilerOptions": {
        "paths": {
            "*": ["./*"],
            "src/*": ["./src/*"],
            "@repo/fe-ui/*": ["../../../../packages/fe/ui/src/exports/*"],
            "config": ["../../../../config/index"],
            "@repo/fe-utils": ["../../../../packages/fe/utils/src"],
            "measurement/MapToolBridge": [
                "../../../../apps/fe/remote/measurement/src/features/planar-distance/mapToolBridgePublic.ts"
