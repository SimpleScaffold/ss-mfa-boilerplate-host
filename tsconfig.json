{
    "extends": "../../../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "baseUrl": ".",
        "jsx": "react-jsx",
        "paths": {
            "src/*": ["./src/*"],
            "config": ["../../../../config/index"],
            "@repo/fe-ui/*": ["../../../../packages/fe/ui/src/exports/*"]
        },
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "skipLibCheck": true
    },
    "include": ["src"]
}
